{
    "config": {
        "engine": [
            "venv",
            "colab"
        ]
    },
    "base": {
        "behavior": {
            "on_failure": "terminate"
        },
        "infra": [
            "is_connected_to_internet",
            "is_root_absolute_path_configured",
            "is_engine_installed"
        ]
    },
    "extra": {
        "behavior": {
            "on_failure": "warning"
        },
        "infra": [
            "is_storage_installed"
        ]
    },
    "engine": {
        "venv": {
            "infra": [
                "is_venv_active",
                "install_python_dependencies",
                "install_spacy_models"
            ]
        },
        "colab": {
            "infra": [
                "is_colab",
                "install_python_dependencies",
                "install_spacy_models"
            ]
        }
    }
}
